{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.js": { "maxDuration": 15, "memory": 256 }
  },
  "headers": [
    {
      "source": "/(css|js|data|assets)/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=600, must-revalidate" }]
    }
  ],
  "rewrites": [
    { "source": "/((?!api/|css/|js/|data/|assets/|favicon).*)", "destination": "/index.html" }
  ]
}
