# Inside IR Ferrovial — environment variables (set these in Vercel → Settings → Environment Variables)
#
# IMPORTANT: Yahoo Finance blocks Vercel's serverless IPs, so live market data
# requires a provider that works from servers. Both keys below are FREE.

# Twelve Data — powers live quotes, charts, returns, technicals & peer prices for
# all three listings (Nasdaq / Madrid / Amsterdam). Free key (800 req/day):
# https://twelvedata.com/pricing  → sign up → API key.
TWELVEDATA_API_KEY=

# Finnhub — powers the News feed (and a US-quote fallback). Free key:
# https://finnhub.io/register
FINNHUB_API_KEY=
